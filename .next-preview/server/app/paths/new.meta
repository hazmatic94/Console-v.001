{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/paths/layout,_N_T_/paths/new/layout,_N_T_/paths/new/page,_N_T_/paths/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/paths/new/__PAGE__",
    "/paths/new",
    "/paths",
    "/_index",
    "/_head"
  ]
}